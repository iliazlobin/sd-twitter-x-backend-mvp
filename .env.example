# Twitter/X MVP — environment variables
# Copy this file to .env and adjust for local development.
#
# In Docker Compose mode, DATABASE_URL and REDIS_URL are set by
# docker-compose.yml's environment: block — they typically don't
# need to be overridden in .env.
#
# APP_PORT controls the HOST port mapping (container always listens
# on port 8000).

# PostgreSQL connection string (asyncpg driver)
# Compose default: postgresql+asyncpg://twitter_x:***@db:5432/twitter_x
DATABASE_URL=

# Redis connection string (timeline cache + trends + fan-out queue)
# Compose default: redis://redis:6379/0
REDIS_URL=

# Host port for Docker Compose (container listens on 8000 internally)
# Default: 8040
APP_PORT=
