# Twitter/X Backend MVP — environment configuration
# Copy this file to .env and uncomment + set values as needed.
#   cp .env.example .env
#
# All keys are listed with safe defaults shown; the app works out of
# the box with compose-provided infrastructure — only APP_PORT typically
# needs changing.

# Application port on the host (default: 8010)
# APP_PORT=8010

# PostgreSQL connection string (default: compose-internal)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/twitter_x

# Redis connection string (default: compose-internal)
# REDIS_URL=redis://redis:6379/0
